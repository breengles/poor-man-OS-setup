{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(git add:*)",
      "Bash(git ls-files:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Edit(~/.claude/settings.json)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "mcpServers": {
    "gitlab-cli": {
      "type": "stdio",
      "command": "glab",
      "args": [
        "mcp",
        "serve"
      ],
      "env": {}
    }
  }
}
