{
  "permissions": {
    "allow": [
      "Read",
      "WebSearch",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/settings.local.json)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Bash(pre-commit:*)",
      "Bash(pre-commit run:*)",
      "Bash(ruff:*)",
      "Bash(uv:*)",
      "Bash(grep:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(git:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(npx prettier:*)",
      "Bash(glab issue list:*)",
      "Bash(glab issue view:*)",
      "Bash(glab mr list:*)",
      "Bash(glab mr view:*)",
      "Bash(glab mr diff:*)",
      "Bash(glab repo view:*)",
      "Bash(glab repo list:*)",
      "Bash(glab ci list:*)",
      "Bash(glab ci status:*)",
      "Bash(glab ci get:*)",
      "Bash(glab ci trace:*)",
      "Bash(glab label list:*)",
      "Bash(glab milestone list:*)",
      "Bash(glab release list:*)",
      "Bash(glab release view:*)",
      "Bash(glab auth status:*)",
      "Bash(glab api:*)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/settings.local.json)",
      "Write(**/.claude/settings.json)",
      "Write(**/.claude/settings.local.json)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "mcpServers": {
    "gitlab-cli": {
      "type": "stdio",
      "command": "glab",
      "args": ["mcp", "serve"],
      "env": {}
    }
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
