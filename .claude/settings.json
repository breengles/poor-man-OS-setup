{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "mcp__gitlab-cli__*",
      "Edit(~/.claude/settings.json)",
      "Edit(~/.claude/settings.local.json)",
      "Edit(**/.claude/settings.json)",
      "Edit(**/.claude/settings.local.json)",
      "Bash(pre-commit *)",
      "Bash(chmod +x *)",
      "Bash(ruff *)",
      "Bash(uv *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(tree *)",
      "Bash(ls *)",
      "Bash(git *)",
      "Bash(sed *)",
      "Bash(find *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(diff *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(env *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(date *)",
      "Bash(uname *)",
      "Bash(printenv *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(shasum *)",
      "Bash(md5 *)",
      "Bash(df *)",
      "Bash(npx prettier *)",
      "Bash(glab *)",
      "Bash(rm /tmp*)",
      "Bash(rm -rf /tmp*)",
      "Write(~/.claude/settings.json)",
      "Write(~/.claude/settings.local.json)",
      "Write(**/.claude/settings.json)",
      "Write(**/.claude/settings.local.json)"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git push --force *)",
      "Bash(git push * --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push * --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git merge *)",
      "Bash(glab issue close *)",
      "Bash(glab issue delete *)",
      "Bash(glab mr close *)",
      "Bash(glab mr delete *)",
      "Bash(glab mr merge *)",
      "Bash(glab repo delete *)",
      "Bash(glab release delete *)",
      "Bash(glab label delete *)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "ast-index@ast-index-marketplace": true,
    "picsart@picsart-marketplace": true
  },
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "gitlab-cli": {
      "type": "stdio",
      "command": "glab",
      "args": ["mcp", "serve"],
      "env": {}
    }
  }
}
