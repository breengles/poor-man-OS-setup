{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mode": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "awk *": "allow",
          "basename *": "allow",
          "cat *": "allow",
          "chmod +x *": "allow",
          "cut *": "allow",
          "date *": "allow",
          "df *": "allow",
          "diff *": "allow",
          "dirname *": "allow",
          "du *": "allow",
          "echo *": "allow",
          "env *": "allow",
          "file *": "allow",
          "find *": "allow",
          "git *": "allow",
          "git branch -D *": "ask",
          "git checkout -- *": "ask",
          "git clean *": "ask",
          "git merge *": "ask",
          "git push * --force *": "ask",
          "git push * --force-with-lease *": "ask",
          "git push --force *": "ask",
          "git push --force-with-lease *": "ask",
          "git rebase *": "ask",
          "git reset --hard *": "ask",
          "glab *": "allow",
          "grep *": "allow",
          "head *": "allow",
          "hostname": "allow",
          "id": "allow",
          "jq *": "allow",
          "less *": "allow",
          "ls *": "allow",
          "md5 *": "allow",
          "npx prettier *": "allow",
          "pre-commit *": "allow",
          "printenv *": "allow",
          "pwd": "allow",
          "readlink *": "allow",
          "realpath *": "allow",
          "rm *": "deny",
          "rmdir *": "deny",
          "ruff *": "allow",
          "sed *": "allow",
          "shasum *": "allow",
          "sort *": "allow",
          "stat *": "allow",
          "tail *": "allow",
          "tree *": "allow",
          "type *": "allow",
          "uname *": "allow",
          "uniq *": "allow",
          "uv *": "allow",
          "wc *": "allow",
          "which *": "allow",
          "whoami": "allow",
          "xargs *": "allow",
          "yq *": "allow"
        },
        "edit": {
          "*": "allow"
        },
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow"
        }
      }
    }
  },
  "share": "disabled"
}
