{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "autoupdate": true,
  "enabled_providers": ["anthropic"],
  "share": "manual",
  "keybinds": {
    "model_cycle_favorite": "shift+tab",
    "model_cycle_favorite_reverse": "none",
    "agent_cycle_reverse": "none"
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "bash": {
      "*": "ask",
      "pre-commit *": "allow",
      "chmod +x *": "allow",
      "ruff *": "allow",
      "uv *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "tree *": "allow",
      "ls *": "allow",
      "git *": "allow",
      "git push --force *": "ask",
      "git push * --force *": "ask",
      "git push --force-with-lease *": "ask",
      "git push * --force-with-lease *": "ask",
      "git reset --hard *": "ask",
      "git checkout -- *": "ask",
      "git clean *": "ask",
      "git branch -D *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask",
      "sed *": "allow",
      "find *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "diff *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "which *": "allow",
      "type *": "allow",
      "env *": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "npx prettier *": "allow",
      "glab *": "allow",
      "glab issue close *": "ask",
      "glab issue delete *": "ask",
      "glab mr close *": "ask",
      "glab mr delete *": "ask",
      "glab mr merge *": "ask",
      "glab repo delete *": "ask",
      "glab release delete *": "ask",
      "glab label delete *": "ask",
      "rm *": "deny",
      "rmdir *": "deny"
    }
  },
  "agent": {
    "explore": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "general": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "title": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "summary": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "compaction": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "mcp": {
    "gitlab-cli": {
      "type": "local",
      "command": ["glab", "mcp", "serve"],
      "enabled": true
    }
  },
  "formatter": {
    "ruff": {},
    "prettier": {},
    "custom-prettier-md": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".md"]
    }
  }
}
